{
  "name": "emerge",
  "version": "0.2.0",
  "description": "Generic RWB flywheel plugin for Claude Code",
  "mcpServers": {
    "emerge": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/repl_daemon.py"]
    }
  },
  "permissions": {
    "filesystem": ["~/.emerge/"],
    "network": ["localhost", "192.168.122.0/24"]
  }
}
